<mujoco model="Unitree H1-2 Scene">

  <!-- Incluye el robot -->
  <include file="h1_2_hand.xml"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6"
               ambient="0.2 0.2 0.2"
               specular="0.9 0.9 0.9"/>

    <!-- Fondo azul -->
    <rgba haze="0.6 0.8 1 1"/>

    <global azimuth="-140" elevation="-25"/>
  </visual>

  <asset>
    <!-- Cielo azul degradado -->
    <texture name="skybox"
             type="skybox"
             builtin="gradient"
             rgb1="0.4 0.7 1"
             rgb2="0.1 0.3 0.8"
             width="512"
             height="512"/>

    <!-- Piso cuadriculado -->
    <texture type="2d"
             name="ground_tex"
             builtin="checker"
             rgb1="0.8 0.8 0.8"
             rgb2="0.2 0.2 0.2"
             width="300"
             height="300"/>

    <material name="ground_mat"
              texture="ground_tex"
              texrepeat="10 10"
              reflectance="0.2"/>
  </asset>

  <worldbody>

    <!-- Luz principal -->
    <light pos="0 0 3"
           dir="0 0 -1"
           directional="true"/>

    <!-- Piso (IMPORTANTE: tamaño > 0) -->
    <geom name="floor"
          type="plane"
          size="5 5 0.1"
          material="ground_mat"/>

  </worldbody>

</mujoco>