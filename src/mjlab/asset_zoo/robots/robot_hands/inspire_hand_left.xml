<mujoco model="inspire_hand_left">
  <compiler angle="radian" meshdir="./meshes"/>

  <asset>
    <mesh name="L_hand_base_link" file="L_hand_base_link.STL"/>
    <mesh name="Link11_L" file="Link11_L.STL"/>
    <mesh name="Link12_L" file="Link12_L.STL"/>
    <mesh name="Link13_L" file="Link13_L.STL"/>
    <mesh name="Link14_L" file="Link14_L.STL"/>
    <mesh name="Link15_L" file="Link15_L.STL"/>
    <mesh name="Link16_L" file="Link16_L.STL"/>
    <mesh name="Link17_L" file="Link17_L.STL"/>
    <mesh name="Link18_L" file="Link18_L.STL"/>
    <mesh name="Link19_L" file="Link19_L.STL"/>
    <mesh name="Link20_L" file="Link20_L.STL"/>
    <mesh name="Link21_L" file="Link21_L.STL"/>
    <mesh name="Link22_L" file="Link22_L.STL"/>
  </asset>

  <worldbody>
    <!-- ── Base de la mano ─────────────────────────────────────────── -->
    <body name="L_hand_base_link" pos="0 0 0">
      <inertial pos="-0.002551 -0.066047 -0.0019357" mass="0.14143"
                fullinertia="0.0001234 8.3835e-05 7.7231e-05 2.1995e-06 -1.7694e-06 1.5968e-06"/>
      <!-- Visual -->
      <geom name="L_hand_base_visual" type="mesh" mesh="L_hand_base_link"
            contype="0" conaffinity="0" group="1" rgba="0.8 0.8 0.8 1"/>
      <!-- Colisión base (cápsula simplificada) -->
      <geom name="L_hand_base_col" type="capsule" size="0.018" fromto="0 -0.04 0  0 -0.1 0"
            rgba="0.2 0.8 0.2 0.3"/>

      <!-- ── PULGAR ──────────────────────────────────────────────── -->
      <body name="L_thumb_proximal_base" pos="-0.01696 -0.0691 0.02045"
            quat="0.499998 0.5 -0.5 0.500002">
        <inertial pos="0.0048817 0.00038782 -0.00722" mass="0.0018869"
                  diaginertia="8.66031e-08 6.87331e-08 4.94199e-08"/>
        <joint name="L_thumb_proximal_yaw_joint" axis="0 0 1"
               range="-0.1 1.3" damping="0.05" frictionloss="0.01"/>
        <geom type="mesh" mesh="Link11_L" contype="0" conaffinity="0" group="1" rgba="0.8 0.8 0.8 1"/>
        <geom type="capsule" size="0.007" fromto="0 0 0  0.01 0.01 -0.009"
              rgba="0.2 0.8 0.2 0.3"/>

        <body name="L_thumb_proximal" pos="0.0099867 0.0098242 -0.0089"
              quat="0.704571 -0.704573 -0.0598169 0.0598167">
          <inertial pos="0.021936 -0.01279 -0.0080386" mass="0.0066101"
                    diaginertia="2.78701e-06 2.44024e-06 8.6466e-07"/>
          <joint name="L_thumb_proximal_pitch_joint" axis="0 0 -1"
                 range="0 0.5" damping="0.05" frictionloss="0.01"/>
          <geom type="mesh" mesh="Link12_L" contype="0" conaffinity="0" group="1" rgba="0.8 0.8 0.8 1"/>
          <geom type="capsule" size="0.007" fromto="0 0 0  0.044 -0.035 -0.001"
                rgba="0.2 0.8 0.2 0.3"/>

          <body name="L_thumb_intermediate" pos="0.04407 -0.034553 -0.0008">
            <inertial pos="0.0095531 0.0016282 -0.0072002" mass="0.0037844"
                      diaginertia="4.6532e-07 4.48114e-07 2.45646e-07"/>
            <joint name="L_thumb_intermediate_joint" axis="0 0 -1"
                   range="0 0.8" damping="0.05" frictionloss="0.01"/>
            <geom type="mesh" mesh="Link13_L" contype="0" conaffinity="0" group="1" rgba="0.8 0.8 0.8 1"/>
            <geom type="capsule" size="0.007" fromto="0 0 0  0.02 -0.01 -0.001"
                  rgba="0.2 0.8 0.2 0.3"/>

            <body name="L_thumb_distal" pos="0.020248 -0.010156 -0.0012">
              <inertial pos="0.0092888 -0.004953 -0.0060033" mass="0.003344"
                        diaginertia="2.0026e-07 1.95246e-07 8.1594e-08"/>
              <joint name="L_thumb_distal_joint" axis="0 0 -1"
                     range="0 1.2" damping="0.05" frictionloss="0.01"/>
              <geom type="mesh" mesh="Link14_L" contype="0" conaffinity="0" group="1" rgba="0.8 0.8 0.8 1"/>
              <geom type="capsule" size="0.007" fromto="0 0 0  0.015 -0.013 -0.004"
                    rgba="0.2 0.8 0.2 0.3"/>
              <!-- Fingertip site -->
              <site name="L_thumb_tip" pos="0.015 -0.013 -0.004" size="0.005" rgba="1 0 0 1"/>
            </body>
          </body>
        </body>
      </body>

      <!-- ── ÍNDICE ──────────────────────────────────────────────── -->
      <body name="L_index_proximal" pos="0.00028533 -0.13653 0.032268"
            quat="0.999848 -0.0174526 0 0">
        <inertial pos="0.0012971 -0.011934 -0.0059998" mass="0.0042405"
                  diaginertia="6.9402e-07 6.62904e-07 2.10916e-07"/>
        <joint name="L_index_proximal_joint" axis="0 0 -1"
               range="0 1.7" damping="0.05" frictionloss="0.01"/>
        <geom type="mesh" mesh="Link15_L" contype="0" conaffinity="0" group="1" rgba="0.8 0.8 0.8 1"/>
        <geom type="capsule" size="0.007" fromto="0 0 0  -0.002 -0.032 -0.001"
              rgba="0.2 0.8 0.2 0.3"/>

        <body name="L_index_intermediate" pos="-0.0024229 -0.032041 -0.001">
          <inertial pos="0.0021753 -0.019567 -0.005" mass="0.0045682"
                    diaginertia="7.8176e-07 7.72427e-07 8.47209e-08"/>
          <joint name="L_index_intermediate_joint" axis="0 0 -1"
                 range="0 1.7" damping="0.05" frictionloss="0.01"/>
          <geom type="mesh" mesh="Link16_L" contype="0" conaffinity="0" group="1" rgba="0.8 0.8 0.8 1"/>
          <geom type="capsule" size="0.007" fromto="0 0 0  -0.005 -0.04 -0.004"
                rgba="0.2 0.8 0.2 0.3"/>
          <site name="L_index_tip" pos="-0.005 -0.04 -0.004" size="0.005" rgba="0 1 0 1"/>
        </body>
      </body>

      <!-- ── CORAZÓN ─────────────────────────────────────────────── -->
      <body name="L_middle_proximal" pos="0.00028533 -0.1371 0.01295">
        <inertial pos="0.0012971 -0.011934 -0.0059999" mass="0.0042405"
                  diaginertia="6.9402e-07 6.62904e-07 2.10916e-07"/>
        <joint name="L_middle_proximal_joint" axis="0 0 -1"
               range="0 1.7" damping="0.05" frictionloss="0.01"/>
        <geom type="mesh" mesh="Link17_L" contype="0" conaffinity="0" group="1" rgba="0.8 0.8 0.8 1"/>
        <geom type="capsule" size="0.007" fromto="0 0 0  -0.002 -0.032 -0.001"
              rgba="0.2 0.8 0.2 0.3"/>

        <body name="L_middle_intermediate" pos="-0.0024229 -0.032041 -0.001">
          <inertial pos="0.001921 -0.020796 -0.0049999" mass="0.0050397"
                    diaginertia="9.8385e-07 9.73288e-07 9.14016e-08"/>
          <joint name="L_middle_intermediate_joint" axis="0 0 -1"
                 range="0 1.7" damping="0.05" frictionloss="0.01"/>
          <geom type="mesh" mesh="Link18_L" contype="0" conaffinity="0" group="1" rgba="0.8 0.8 0.8 1"/>
          <geom type="capsule" size="0.007" fromto="0 0 0  -0.005 -0.045 -0.004"
                rgba="0.2 0.8 0.2 0.3"/>
          <site name="L_middle_tip" pos="-0.005 -0.045 -0.004" size="0.005" rgba="0 0 1 1"/>
        </body>
      </body>

      <!-- ── ANULAR ───────────────────────────────────────────────── -->
      <body name="L_ring_proximal" pos="0.00028533 -0.13691 -0.0062872"
            quat="0.999657 0.026177 0 0">
        <inertial pos="0.0012971 -0.011934 -0.0059999" mass="0.0042405"
                  diaginertia="6.9402e-07 6.62904e-07 2.10916e-07"/>
        <joint name="L_ring_proximal_joint" axis="0 0 -1"
               range="0 1.7" damping="0.05" frictionloss="0.01"/>
        <geom type="mesh" mesh="Link19_L" contype="0" conaffinity="0" group="1" rgba="0.8 0.8 0.8 1"/>
        <geom type="capsule" size="0.007" fromto="0 0 0  -0.002 -0.032 -0.001"
              rgba="0.2 0.8 0.2 0.3"/>

        <body name="L_ring_intermediate" pos="-0.0024229 -0.032041 -0.001">
          <inertial pos="0.0021753 -0.019567 -0.005" mass="0.0045682"
                    diaginertia="7.8176e-07 7.72437e-07 8.47208e-08"/>
          <joint name="L_ring_intermediate_joint" axis="0 0 -1"
                 range="0 1.7" damping="0.05" frictionloss="0.01"/>
          <geom type="mesh" mesh="Link20_L" contype="0" conaffinity="0" group="1" rgba="0.8 0.8 0.8 1"/>
          <geom type="capsule" size="0.007" fromto="0 0 0  -0.002 -0.04 -0.004"
                rgba="0.2 0.8 0.2 0.3"/>
          <site name="L_ring_tip" pos="-0.002 -0.04 -0.004" size="0.005" rgba="0 1 1 1"/>
        </body>
      </body>

      <!-- ── MEÑIQUE ─────────────────────────────────────────────── -->
      <body name="L_pinky_proximal" pos="0.00028533 -0.13571 -0.025488"
            quat="0.99863 0.0523361 0 0">
        <inertial pos="0.0012971 -0.011934 -0.0059999" mass="0.0042405"
                  diaginertia="6.9402e-07 6.62904e-07 2.10916e-07"/>
        <joint name="L_pinky_proximal_joint" axis="0 0 -1"
               range="0 1.7" damping="0.05" frictionloss="0.01"/>
        <geom type="mesh" mesh="Link21_L" contype="0" conaffinity="0" group="1" rgba="0.8 0.8 0.8 1"/>
        <geom type="capsule" size="0.007" fromto="0 0 0  -0.002 -0.032 -0.001"
              rgba="0.2 0.8 0.2 0.3"/>

        <body name="L_pinky_intermediate" pos="-0.0024229 -0.032041 -0.001">
          <inertial pos="0.0024788 -0.016208 -0.0050001" mass="0.0036036"
                    diaginertia="4.4881e-07 4.43809e-07 6.5736e-08"/>
          <joint name="L_pinky_intermediate_joint" axis="0 0 -1"
                 range="0 1.7" damping="0.05" frictionloss="0.01"/>
          <geom type="mesh" mesh="Link22_L" contype="0" conaffinity="0" group="1" rgba="0.8 0.8 0.8 1"/>
          <geom type="capsule" size="0.007" fromto="0 0 0  -0.002 -0.032 -0.004"
                rgba="0.2 0.8 0.2 0.3"/>
          <site name="L_pinky_tip" pos="-0.002 -0.032 -0.004" size="0.005" rgba="1 1 1 1"/>
        </body>
      </body>

    </body>
  </worldbody>

  <!-- ── Actuadores (solo joints proximales, los 6 del inspire_hand.yml) ── -->
  <actuator>
    <position name="act_L_thumb_yaw"   joint="L_thumb_proximal_yaw_joint"   kp="2" ctrlrange="-0.1 1.3"/>
    <position name="act_L_thumb_pitch" joint="L_thumb_proximal_pitch_joint" kp="2" ctrlrange="0 0.5"/>
    <position name="act_L_index"       joint="L_index_proximal_joint"       kp="2" ctrlrange="0 1.7"/>
    <position name="act_L_middle"      joint="L_middle_proximal_joint"      kp="2" ctrlrange="0 1.7"/>
    <position name="act_L_ring"        joint="L_ring_proximal_joint"        kp="2" ctrlrange="0 1.7"/>
    <position name="act_L_pinky"       joint="L_pinky_proximal_joint"       kp="2" ctrlrange="0 1.7"/>
  </actuator>

  <!-- ── Joints mimicados (intermediate sigue al proximal) ── -->
  <!-- joint1 = polycoef[0] + polycoef[1]*joint2 -->
  <equality>
    <joint name="mimic_thumb_intermediate" joint1="L_thumb_intermediate_joint" joint2="L_thumb_proximal_pitch_joint" polycoef="0 1.6 0 0 0"/>
    <joint name="mimic_thumb_distal"       joint1="L_thumb_distal_joint"       joint2="L_thumb_proximal_pitch_joint" polycoef="0 2.4 0 0 0"/>
    <joint name="mimic_index_intermediate" joint1="L_index_intermediate_joint" joint2="L_index_proximal_joint"       polycoef="0 1.0 0 0 0"/>
    <joint name="mimic_middle_intermediate" joint1="L_middle_intermediate_joint" joint2="L_middle_proximal_joint"    polycoef="0 1.0 0 0 0"/>
    <joint name="mimic_ring_intermediate"  joint1="L_ring_intermediate_joint"  joint2="L_ring_proximal_joint"        polycoef="0 1.0 0 0 0"/>
    <joint name="mimic_pinky_intermediate" joint1="L_pinky_intermediate_joint" joint2="L_pinky_proximal_joint"       polycoef="0 1.0 0 0 0"/>
  </equality>

</mujoco>