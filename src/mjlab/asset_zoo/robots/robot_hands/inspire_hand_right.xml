  <!-- ── Actuadores (6 joints proximales, igual que inspire_hand.yml) ── -->
  <actuator>
    <position name="act_R_thumb_yaw"   joint="R_thumb_proximal_yaw_joint"   kp="2" ctrlrange="-0.1 1.3"/>
    <position name="act_R_thumb_pitch" joint="R_thumb_proximal_pitch_joint" kp="2" ctrlrange="0 0.5"/>
    <position name="act_R_index"       joint="R_index_proximal_joint"       kp="2" ctrlrange="0 1.7"/>
    <position name="act_R_middle"      joint="R_middle_proximal_joint"      kp="2" ctrlrange="0 1.7"/>
    <position name="act_R_ring"        joint="R_ring_proximal_joint"        kp="2" ctrlrange="0 1.7"/>
    <position name="act_R_pinky"       joint="R_pinky_proximal_joint"       kp="2" ctrlrange="0 1.7"/>
  </actuator>

  <!-- ── Joints mimicados (igual que el URDF original) ── -->
  <equality>
    <joint name="mimic_R_thumb_intermediate" joint1="R_thumb_intermediate_joint" joint2="R_thumb_proximal_pitch_joint" polycoef="0 1.6 0 0 0"/>
    <joint name="mimic_R_thumb_distal"       joint1="R_thumb_distal_joint"       joint2="R_thumb_proximal_pitch_joint" polycoef="0 2.4 0 0 0"/>
    <joint name="mimic_R_index_intermediate" joint1="R_index_intermediate_joint" joint2="R_index_proximal_joint"       polycoef="0 1.0 0 0 0"/>
    <joint name="mimic_R_middle_intermediate" joint1="R_middle_intermediate_joint" joint2="R_middle_proximal_joint"    polycoef="0 1.0 0 0 0"/>
    <joint name="mimic_R_ring_intermediate"  joint1="R_ring_intermediate_joint"  joint2="R_ring_proximal_joint"        polycoef="0 1.0 0 0 0"/>
    <joint name="mimic_R_pinky_intermediate" joint1="R_pinky_intermediate_joint" joint2="R_pinky_proximal_joint"       polycoef="0 1.0 0 0 0"/>
  </equality>

</mujoco>